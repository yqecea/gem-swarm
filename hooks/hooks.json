{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}/hooks/hook-runner.js\" gemini session-start",
            "name": "gem-swarm-session-start",
            "description": "Initialize hook state and prune stale sessions",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}/hooks/hook-runner.js\" gemini before-agent",
            "name": "gem-swarm-before-agent",
            "description": "Inject session context into agent turns",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}/hooks/hook-runner.js\" gemini before-tool",
            "name": "gem-swarm-git-checkpoint",
            "description": "Create git stash checkpoint before file modifications",
            "timeout": 15000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}/hooks/hook-runner.js\" gemini after-agent",
            "name": "gem-swarm-after-agent",
            "description": "Validate handoff report format with retry on malformed output",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${extensionPath}/hooks/hook-runner.js\" gemini session-end",
            "name": "gem-swarm-session-end",
            "description": "Clean up hook state for ended session",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
